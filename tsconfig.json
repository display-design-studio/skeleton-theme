{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@ts/*": ["frontend/entrypoints/ts/*"],
      "@css/*": ["frontend/entrypoints/css/*"]
    },
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "checkJs": false,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
  },
  "include": ["frontend/**/*.ts", "vite.config.js"],
}
