{
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-shopify": "^4.1.1"
  },
  "type": "module",
  "scripts": {
    "dev": "run-p -sr \"shopify:dev -- {@}\" \"vite:dev\" --",
    "build": "vite build",
    "dev:remote": "SHOPIFY_VITE_TUNNEL=true run-p -sr \"shopify:dev -- {@}\" \"vite:dev\" --",
    "deploy": "run-s \"vite:build\" \"shopify:push -- {@}\" --",
    "shopify:dev": "shopify theme dev --environment development",
    "shopify:push": "shopify theme push",
    "typecheck": "tsc --noEmit",
    "vite:dev": "vite",
    "vite:build": "vite build"
  }
}
